{
  "name": "day_plan",
  "agents": ["day_plan_researcher", "day_plan_planner"],
  "tasks": [
    {
      "name": "research_day_places_task",
      "description": "Research places for a single travel day.\n\nContext:\n- overnight_city: {overnight_city}\n- day_index: {day_index}\n- date: {date}\n- origin: {origin}\n- destination: {destination} (destination_type={destination_type})\n- preferences: {preferences}\n- already_visited (do NOT recommend these place_keys or obvious duplicates): {already_visited}\n- prior_days_summary: {prior_days_summary}\n- city_route_json (confirmed route; overnight_city must match): {city_route_json}\n\nUse web search for real venues in {overnight_city}. Gather name, address, maps/website URLs when possible, category, why it fits this day, estimated visit minutes, and bathroom availability if known.\n\nDo not plan other days. Do not change overnight_city.",
      "expected_output": "A research brief listing 5–10 candidate places for this day with practical details (name, address, URLs, category, minutes, bathroom if known). Exclude anything matching already_visited.",
      "agent": "day_plan_researcher"
    },
    {
      "name": "compose_day_plan_task",
      "description": "Using the research brief, produce a DayPlan for day {day_index} on {date}.\n\nConstraints:\n- overnight_city must be exactly: {overnight_city}\n- day_index must be {day_index}\n- date must be {date}\n- Include 3–6 Place stops (paced for one day)\n- Each Place needs: name, address (if known), category, reason_to_visit, details, estimated_minutes (>0), order_in_day, maps_url/website_url when known, has_bathroom (true/false/null), place_key (normalize name|address lowercase)\n- Do not reuse keys in already_visited: {already_visited}\n- theme and summary should be short\n- No Markdown report — structured DayPlan only",
      "expected_output": "A DayPlan object with day_index, date, theme, summary, overnight_city, and places[3-6] each with name, category, reason_to_visit, details, estimated_minutes, order_in_day, place_key, and optional address/urls/has_bathroom.",
      "agent": "day_plan_planner",
      "context": ["research_day_places_task"],
      "output_pydantic": { "python": "day_models.DayPlan" }
    }
  ],
  "process": "sequential",
  "verbose": true,
  "memory": false,
  "output_log_file": "logs/crew.log",
  "stream": false,
  "tracing": true,
  "inputs": {
    "origin": "San Francisco",
    "destination": "Japan",
    "destination_type": "country",
    "day_index": "1",
    "date": "2026-09-01",
    "overnight_city": "Tokyo",
    "preferences": "culture, food, moderate pace",
    "already_visited": "",
    "prior_days_summary": "",
    "city_route_json": ""
  }
}
