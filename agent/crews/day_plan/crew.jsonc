{
  "name": "day_plan",
  "agents": ["day_plan_researcher", "day_plan_planner", "day_plan_reviewer"],
  "tasks": [
    {
      "name": "research_day_places_task",
      "description": "Research places for a single travel day.\n\nContext:\n- overnight_city: {overnight_city}\n- day_index: {day_index}\n- date: {date}\n- origin: {origin}\n- destination: {destination} (destination_type={destination_type})\n- preferences: {preferences}\n- interests: {interests}\n- energy_level: {energy_level} (max comfortable day minutes including travel: {max_comfortable_minutes})\n- already_visited (do NOT recommend these place_keys or obvious duplicates): {already_visited}\n- prior_days_summary: {prior_days_summary}\n- city_route_json (confirmed route; overnight_city must match): {city_route_json}\n\nUse web search for real venues in {overnight_city}. Prefer places that are open (not permanently closed) and open on {date}'s weekday when you can tell. Gather name, address, maps/website URLs, category, why it fits, estimated visit minutes, bathroom if known, operational_status (open|closed|unknown), closed_weekdays (Mon=0..Sun=6) when known, and open_hours text when known.\n\nDo not plan other days. Do not change overnight_city.",
      "expected_output": "A research brief listing 5–10 candidate places with practical details including operational_status / hours when known. Exclude already_visited and known permanently closed venues.",
      "agent": "day_plan_researcher"
    },
    {
      "name": "compose_day_plan_task",
      "description": "Using the research brief, produce a draft DayPlan for day {day_index} on {date}.\n\nConstraints:\n- overnight_city must be exactly: {overnight_city}\n- day_index must be {day_index}\n- date must be {date}\n- Include 3–6 Place stops; keep sum(estimated_minutes + travel_minutes_from_previous) near or under {max_comfortable_minutes}\n- Each Place needs: name, address (if known), category, reason_to_visit, details, estimated_minutes (>0), order_in_day, maps_url/website_url when known, has_bathroom, place_key, operational_status, closed_weekdays (list of 0–6), open_hours when known, travel_minutes_from_previous (0 for first)\n- Prefer stops that match the traveler preferences/interests already applied in research\n- Do not reuse already_visited keys (the full forbidden list was applied in research — never reintroduce excluded venues)\n- theme and summary should be short\n- No Markdown report — structured DayPlan only",
      "expected_output": "A draft DayPlan with places[3-6] including operational_status and closed_weekdays when known.",
      "agent": "day_plan_planner",
      "context": ["research_day_places_task"],
      "output_pydantic": { "python": "day_models.DayPlan" }
    },
    {
      "name": "review_day_plan_task",
      "description": "Review the draft DayPlan against traveler context and the research brief. Produce a corrected final DayPlan.\n\nMust enforce:\n- Drop places with operational_status=closed\n- Drop places whose closed_weekdays includes the weekday of {date} (Mon=0..Sun=6)\n- Drop duplicates and any stop the research brief already excluded as already_visited (do not reintroduce forbidden keys)\n- Keep overnight_city={overnight_city}, day_index={day_index}, date={date}\n- Final places MUST remain 3–6 (replace dropped stops from the research brief only; do not invent venues or hours)\n- Sum of estimated_minutes + travel_minutes_from_previous must not exceed {max_comfortable_minutes} (energy_level={energy_level})\n- Prefer stops aligned with the preferences/interests already applied in research\n- You have no tools — no new research; dubious stops → swap from the brief or drop and replace\n\nOutput structured DayPlan only (no Markdown essay).",
      "expected_output": "A final DayPlan with 3–6 open venues under the energy cap.",
      "agent": "day_plan_reviewer",
      "context": ["research_day_places_task", "compose_day_plan_task"],
      "output_pydantic": { "python": "day_models.DayPlan" }
    }
  ],
  "process": "sequential",
  "verbose": true,
  "memory": false,
  "output_log_file": "logs/crew.log",
  "stream": false,
  "tracing": true,
  "inputs": {
    "origin": "San Francisco",
    "destination": "Japan",
    "destination_type": "country",
    "day_index": "1",
    "date": "2026-09-01",
    "overnight_city": "Tokyo",
    "preferences": "culture, food, moderate pace",
    "interests": "temples, food",
    "energy_level": "3",
    "max_comfortable_minutes": "510",
    "already_visited": "",
    "prior_days_summary": "",
    "city_route_json": ""
  }
}
