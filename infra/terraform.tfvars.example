aws_region   = "us-east-1"
project_name = "vacation-planner"
environment  = "dev"

# Cognito Hosted UI social IdPs (optional — leave empty for Cognito email/password only)
google_client_id     = ""
google_client_secret = ""
facebook_app_id      = ""
facebook_app_secret  = ""
# Prefer TF_VAR_google_client_* / TF_VAR_facebook_app_* env vars over committing secrets.

# After first CloudFront deploy, add THAT stack's site URL here and re-apply
# (terraform output frontend_site_url). Do not copy another environment's URL.
callback_urls = [
  "http://localhost:5173/callback",
  "https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net/callback",
]
logout_urls = [
  "http://localhost:5173/",
  "https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net/",
]

# AgentCore is required for AWS deploy (API Lambda CREW_MODE=agentcore).
enable_agentcore            = true
agent_runtime_container_uri = "" # prefer TF_VAR_… from build_push_image.sh
# Same IDs as crew llm after "bedrock/" — Terraform expands to IAM ARNs.
agent_bedrock_models = ["us.amazon.nova-pro-v1:0"]
# agent_allowed_bedrock_model_arns = []  # optional full-ARN override (rarely needed)
# serper_api_key                 = ""  # prefer TF_VAR_serper_api_key env var
# google_places_api_key          = ""  # prefer TF_VAR_google_places_api_key (BFF open-status enrich)

# CloudWatch GenAI Observability — account/region singleton (enable in ONE stack per region only).
enable_genai_observability              = true
genai_observability_indexing_percentage = 1 # free tier; raise if you want denser indexed spans
# If Transaction Search is already enabled in this account/region, import first:
#   terraform import 'module.observability.awscc_xray_transaction_search_config.this[0]' <ACCOUNT_ID>
#   terraform import 'module.observability.aws_cloudwatch_log_resource_policy.transaction_search[0]' VacationPlannerTransactionSearchXRay

# Safety: create Guardrail + optionally enable ApplyGuardrail on the API Lambda.
enable_bedrock_guardrails = true
safety_mode               = "keyword" # or "bedrock" / "guardrails" (requires Guardrail ID+ARN)
# Only needed when enable_bedrock_guardrails=false (external Guardrail):
# bedrock_guardrail_id      = ""
# bedrock_guardrail_version = "1"
# bedrock_guardrail_arn     = "arn:aws:bedrock:us-east-1:123456789012:guardrail/abcdef"
